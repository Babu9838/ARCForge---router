"use client";

import { useAccount } from "wagmi";

export default function WalletInfo() {
  const { address, isConnected } = useAccount();

  if (!isConnected) {
    return <p>Wallet not connected</p>;
  }

  return (
    <div>
      <p>Connected Wallet:</p>
      <p>{address}</p>
    </div>
  );
}
